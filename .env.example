# RSVPs are delivered to a Google Sheet + WhatsApp. No email.

# Google Apps Script web-app URL that appends a row to your sheet.
SHEET_WEBHOOK_URL=

# WhatsApp recipients via CallMeBot, comma-separated as "phone:apikey".
# phone = international digits, no + or spaces. apikey = from CallMeBot setup.
# Example: WHATSAPP_RECIPIENTS=9613111111:1234567,9613222222:7654321
WHATSAPP_RECIPIENTS=
