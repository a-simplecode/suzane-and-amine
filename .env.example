# RSVPs are delivered to a Google Sheet + WhatsApp (Twilio). No email.

# Google Apps Script web-app URL that appends a row to your sheet.
SHEET_WEBHOOK_URL=

# Twilio WhatsApp credentials (https://console.twilio.com).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sender: your approved WhatsApp Business sender (or sandbox whatsapp:+14155238886).
TWILIO_WHATSAPP_FROM=whatsapp:+15559581266
# Recipients, comma-separated, full international format with +.
TWILIO_WHATSAPP_TO=+96176466341,+96179174361
# Approved WhatsApp template Content SID (business-initiated messages need this).
TWILIO_CONTENT_SID=
